{
    "name": "receipt-worker",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/receipt-worker/src",
    "projectType": "application",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/webpack:webpack",
            "outputs": ["{options.outputPath}"],
            "options": {
                "target": "node",
                "compiler": "tsc",
                "outputPath": "dist/packages/receipt-worker",
                "main": "packages/receipt-worker/src/main.ts",
                "tsConfig": "packages/receipt-worker/tsconfig.app.json",
                "webpackConfig": "packages/receipt-worker/webpack.config.js"
            }
        },
        "serve": {
            "executor": "@nx/js:node",
            "options": {
                "buildTarget": "receipt-worker:build"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
